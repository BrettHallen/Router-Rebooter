		(uuid "cc2c03c0-ecc8-4c34-8230-86b358c106e1")
	)
	(text_box "Trying to save power by using NC contact so relay coil is de-energised most of the time.\n\nWhen the router needs to be reset then we energise the coil to NO, cutting the through power.\n\nIn case of power loss, well the router will lose power too.  We want to reboot so router power can flow when relay coil is de-energised."
		(exclude_from_sim no)
		(at 119.38 69.85 0)
		(size 54.61 21.59)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "d92494fa-a3c2-4f10-950f-32a3a42a1299")
	)
