	)
	(text_box "Schottky diode prevents regulator back-feeding when USB is connected."
		(exclude_from_sim no)
		(at 193.04 63.5 0)
		(size 73.66 3.81)
		(margins 0.9525 0.9525 0.9525 0.9525)
